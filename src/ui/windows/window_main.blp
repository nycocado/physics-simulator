using Gtk 4.0;

SignalListItemFactory factory_type {}
SignalListItemFactory factory_x {}
SignalListItemFactory factory_y {}
SignalListItemFactory factory_vx {}
SignalListItemFactory factory_vy {}
SignalListItemFactory factory_ax {}
SignalListItemFactory factory_ay {}
SignalListItemFactory factory_mass {}
SignalListItemFactory factory_check {}

menu menu_model {
  submenu {
    label: _("_Projetos");

    item {
      label: _("Abrir");
      action: "win.projects-open";
    }

    item {
      label: _("Novo");
      action: "win.projects-new";
    }

    item {
      label: _("Salvar");
      action: "win.projects-save";
    }

    item {
      label: _("Fechar");
      action: "win.projects-close";
    }
  }
}

Window window_main {
  title: _("Simulador de Cinemática e Dinâmica - Projeto");
  default-width: 1200;
  default-height: 800;

  Box box_all {
    orientation: vertical;

    PopoverMenuBar menu_bar {
      menu-model: menu_model;
    }

    Box box_content {
      homogeneous: true;
      hexpand: true;
      vexpand: true;

      ScrolledWindow scroll {
        has-frame: true;
        hexpand: true;
        vexpand: true;

        ColumnView column_view {
          show-row-separators: true;
          show-column-separators: true;

          ColumnViewColumn column_type {
            title: _("Tipo");
            factory: factory_type;
          }

          ColumnViewColumn column_x {
            title: _("X (m)");
            expand: true;
            factory: factory_x;
          }

          ColumnViewColumn column_y {
            title: _("Y (m)");
            expand: true;
            factory: factory_y;
          }

          ColumnViewColumn column_vx {
            title: _("Vx (m/s)");
            expand: true;
            factory: factory_vx;
          }

          ColumnViewColumn column_vy {
            title: _("Vy (m/s)");
            expand: true;
            factory: factory_vy;
          }

          ColumnViewColumn column_ax {
            title: _("Ax (m/s²)");
            expand: true;
            factory: factory_ax;
          }

          ColumnViewColumn column_ay {
            title: _("Ay (m/s²)");
            expand: true;
            factory: factory_ay;
          }

          ColumnViewColumn column_mass {
            title: _("Massa (kg)");
            expand: true;
            factory: factory_mass;
          }

          ColumnViewColumn column_check {
            title: _("Usar");
            expand: true;
            factory: factory_check;
          }
        }
      }

      Box box_button {
        orientation: vertical;
        homogeneous: true;

        Box table_button {
          halign: start;
          orientation: vertical;

          Button add_particle_button {
            icon-name: "list-add";
            tooltip-text: _("Adicionar partícula");
          }

          Button add_force_button {
            icon-name: "go-down";
            tooltip-text: _("Adicionar força à partícula selecionada");
          }

          Button remove_button {
            icon-name: "list-remove";
            tooltip-text: _("Remover item selecionado");
          }

          Button edit_button {
            icon-name: "document-edit";
            tooltip-text: _("Editar item selecionado");
          }
        }

        Button cinematic_button {
          label: _("Cinemática");

        }

        Button dynamic_button {
          label: _("Dinâmica");

        }
      }
    }
  }
}
