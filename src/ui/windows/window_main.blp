using Gtk 4.0;

menu menu_model {
  submenu {
    label: _("_Projetos");

    item {
      label: _("Abrir");
      action: "win.projects-open";
    }

    item {
      label: _("Novo");
      action: "win.projects-new";
    }

    item {
      label: _("Salvar");
      action: "win.projects-save";
    }

    item {
      label: _("Fechar");
      action: "win.projects-close";
    }
  }
}

Window window_main {
  title: _("Simulador de Cinemática e Dinâmica - Projeto");
  default-width: 1200;
  default-height: 800;

  Box box_all {
    orientation: vertical;

    PopoverMenuBar menu_bar {
      menu-model: menu_model;
    }

    Box box_content {
      homogeneous: true;
      hexpand: true;
      vexpand: true;

      ScrolledWindow scroll {
        has-frame: true;
        hexpand: true;
        vexpand: true;

        ColumnView column_view {
          show-row-separators: true;
          show-column-separators: true;

          [column]
          ColumnViewColumn column_type {
            title: _("tipo");
            factory: SignalListItemFactory factory_type {};
          }

          [column]
          ColumnViewColumn column_x {
            title: _("x");
            expand: true;
            factory: SignalListItemFactory factory_x {};
          }

          [column]
          ColumnViewColumn column_y {
            title: _("y");
            expand: true;
            factory: SignalListItemFactory factory_y {};
          }

          [column]
          ColumnViewColumn column_vx {
            title: _("vx");
            expand: true;
            factory: SignalListItemFactory factory_vx {};
          }

          [column]
          ColumnViewColumn column_vy {
            title: _("vy");
            expand: true;
            factory: SignalListItemFactory factory_vy {};
          }

          [column]
          ColumnViewColumn column_ax {
            title: _("ax");
            expand: true;
            factory: SignalListItemFactory factory_ax {};
          }

          [column]
          ColumnViewColumn column_ay {
            title: _("ay");
            expand: true;
            factory: SignalListItemFactory factory_ay {};
          }

          [column]
          ColumnViewColumn column_mass {
            title: _("massa");
            expand: true;
            factory: SignalListItemFactory factory_mass {};
          }

          [column]
          ColumnViewColumn column_check {
            title: _("usar");
            expand: true;
            factory: SignalListItemFactory factory_check {};
          }
        }
      }

      Box box_button {
        orientation: vertical;
        homogeneous: true;

        Box table_button {
          halign: start;
          orientation: vertical;

          Button add_particle_button {
            icon-name: "list-add";

          }

          Button add_force_button {
            icon-name: "go-down";

          }

          Button remove_button {
            icon-name: "list-remove";

          }

          Button edit_button {
            icon-name: "document-edit";

          }
        }

        Button cinematic_button {
          label: _("Cinemática");

        }

        Button dynamic_button {
          label: _("Dinâmica");

        }
      }
    }
  }
}
